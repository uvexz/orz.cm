/**
 * Configuration for Cloudflare Worker: WR.DO Telegram Bot
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tgbot",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"API_BASE_URL": "https://orz.cm/api/v1",
		"DEFAULT_SHORT_DOMAIN": "orz.cm,shlink.app,signup.li",
		"DEFAULT_EMAIL_DOMAIN": "signup.li,orz.cm,unsend.de"
	},
	"kv_namespaces": [
		{
			"binding": "TGBOT_KV",
			"id": "e6578945efec48eaaf18bee7c0453e3a"
		}
	]
}